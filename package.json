{
  "name": "trackflow-monorepo",
  "private": true,
  "version": "0.1.0",
  "description": "TrackFlow web app (frontend + backend) with CSV-backed user registry and hardcoded Excel DB",
  "workspaces": [
    "frontend",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm run dev --workspace server\" \"npm run dev --workspace frontend\"",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace frontend",
    "start": "npm run start --workspace server",
    "check": "npm run build --workspace frontend",
    "qa:e2e": "playwright test -c playwright.e2e.config.mjs",
    "qa:visual": "playwright test -c playwright.visual.config.mjs",
    "coach:create": "node scripts/create-coach.mjs",
    "db:reset-coach-only": "node scripts/reset-coach-only.mjs",
    "sync:pesas": "node scripts/sync-pesas-db.mjs",
    "seed:rich-demo": "node scripts/seed-rich-demo.mjs",
    "seed:apply": "node scripts/seed-apply.mjs --prime",
    "migrate:mongo": "node scripts/migrate-to-mongo.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "concurrently": "^9.1.2"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "mongodb": "^7.1.0",
    "scoop": "^0.0.2"
  }
}
