{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm ci --include=dev",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "fluid": true,
  "functions": {
    "api/index.mjs": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/jogatina/cron/run",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
