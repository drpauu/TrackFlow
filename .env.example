# App
PORT=8787
CORS_ORIGIN=http://localhost:5173
APP_TIMEZONE=Europe/Madrid
DEFAULT_COACH_ID=coach_default

# Storage mode: local | supabase | mongo
STORAGE_PROVIDER=mongo

# MongoDB (server-only)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_DB=trackflow
MONGO_REQUIRE_AUTH=false

# Auth (server-only)
AUTH_JWT_SECRET=change_this_super_secret
AUTH_JWT_TTL_SEC=1209600
AUTH_COOKIE_NAME=tf_session
AUTH_COOKIE_SECURE=false

# Frontend
VITE_STORAGE_MODE=api
VITE_API_BASE_URL=
VITE_STORAGE_SYNC_INTERVAL_MS=2500
VITE_STORAGE_SYNC_LIMIT=200
VITE_SUPABASE_WRITE_DEBOUNCE_MS=160

# Optional (only if you still run Supabase mode)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_ADMIN_EMAIL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SCHEMA=public
SUPABASE_KV_TABLE=app_kv
SUPABASE_USERS_TABLE=users_csv_registry
SUPABASE_CHANGES_TABLE=app_changes
SUPABASE_REQUEST_TIMEOUT_MS=12000
